# OpenAI
OPENAI_API_KEY=sk-...

# Vercel Blob — logo uploads (get from Vercel dashboard → Storage → Blob → your store)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# JWT — used to sign tokens issued by /api/token
JWT_SECRET=your-secret-here

# API key that Bubble must send when calling /api/token
TOKEN_API_KEY=your-token-api-key-here

# Bubble webhook — existing user approves quote
BUBBLE_WEBHOOK_URL=https://your-app.bubbleapps.io/api/1.1/wf/update_quote
BUBBLE_API_KEY=your-bubble-api-key

# Bubble webhook — guest user submits (creates user + company + quote)
BUBBLE_ONBOARD_URL=https://your-app.bubbleapps.io/api/1.1/wf/onboard_quote

# Redirect after approve (quote_id appended to this base URL)
NEXT_PUBLIC_REDIRECT_BASE=https://app.tik-tok.co.il/version-test/create_quote/

# Bubble webhook — post-approve review (stars + comment)
REVIEW_WEBHOOK_URL=https://your-app.bubbleapps.io/api/1.1/wf/quote_review

# Email existence check before guest submit (optional — if not set, always allows new user)
EMAIL_CHECK_URL=https://your-app.bubbleapps.io/api/1.1/wf/check_email

# Fallback redirect URL for guest after quote saved (if Bubble doesn't return redirect_url)
NEXT_PUBLIC_GUEST_REDIRECT_URL=https://app.tik-tok.co.il/
